# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Secret Key (change this to a secure random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin Credentials (only used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password-in-production

# CORS - Comma-separated list of allowed origins (your frontend URLs)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
